<view class="page-shell">
  <view class="top-bar">
    <view class="row">
      <view class="icon-btn" bindtap="handleBack">返</view>
      <view class="brand-block">
        <view class="brand-avatar"></view>
        <text class="brand-name">FITNOTE</text>
      </view>
    </view>
    <view class="icon-btn" bindtap="goHistory">搜</view>
  </view>

  <view class="hero-card">
    <view class="hero-tag">动作库</view>
    <view class="hero-title">动作库\n<text class="hero-title-accent">引擎</text></view>
    <view class="hero-subtitle">建立个人动作数据库，配合历史记录和 PR 统计做长期进阶。</view>
  </view>

  <view class="section">
    <view class="search-box">
      <input class="search-input" placeholder="搜索动作..." placeholder-style="color:#707363;" bindinput="handleInput" />
    </view>
  </view>

  <view class="section">
    <view class="chip-row">
      <block wx:for="{{categories}}" wx:key="*this">
        <view class="chip {{item === activeCategory ? 'active' : ''}}" data-value="{{item}}" bindtap="selectCategory">{{item}}</view>
      </block>
    </view>
  </view>

  <view class="section">
    <block wx:for="{{exercises}}" wx:key="id">
      <view class="list-card exercise-card" data-id="{{item.id}}" bindtap="goDetail">
        <view class="exercise-icon">{{item.category}}</view>
        <view class="exercise-main">
          <view class="exercise-name">{{item.name}}</view>
          <view class="muted-text">{{item.primaryMuscle}} · {{item.equipment}}</view>
        </view>
        <view class="badge">{{item.difficulty}}</view>
      </view>
    </block>
  </view>

  <bottom-nav active="plan"></bottom-nav>
</view>
