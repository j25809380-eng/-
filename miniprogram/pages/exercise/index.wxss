@import "../../styles/theme.wxss";

.exercise-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.exercise-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(195, 244, 0, 0.24), rgba(195, 244, 0, 0.04));
  color: #c3f400;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.exercise-main {
  flex: 1;
}

.exercise-name {
  font-size: 32rpx;
  font-weight: 800;
}
