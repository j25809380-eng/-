@import "../../styles/theme.wxss";

.progress-card {
  padding: 28rpx;
}

.progress-text {
  font-size: 24rpx;
  color: #8f937f;
}

.progress-bar-bg {
  height: 10rpx;
  border-radius: 5rpx;
  background: rgba(255, 255, 255, 0.06);
  margin-top: 16rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 5rpx;
  background: linear-gradient(90deg, #c3f400, #8EE5FF);
  transition: width 0.3s;
}

.exercise-card {
  padding: 28rpx;
  margin-bottom: 16rpx;
  transition: opacity 0.3s;
  border: 2rpx solid transparent;
}

.exercise-card.done {
  opacity: 0.5;
  border-color: rgba(195, 244, 0, 0.2);
}

.ex-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.ex-badge-row {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.badge.muted {
  background: rgba(255, 255, 255, 0.04);
  color: #707363;
}

.check-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #707363;
  flex-shrink: 0;
}

.check-btn.checked {
  background: rgba(195, 244, 0, 0.2);
  border-color: #c3f400;
  color: #c3f400;
}

.ex-title {
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 6rpx;
}

.ex-muscle {
  font-size: 22rpx;
  color: #8f937f;
  margin-bottom: 18rpx;
}

.ex-params {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
}

.param-item {
  padding: 14rpx 8rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.03);
  text-align: center;
}

.param-num {
  font-size: 26rpx;
  font-weight: 800;
  color: #c3f400;
  display: block;
}

.param-num.weight {
  font-size: 20rpx;
  color: #8EE5FF;
}

.param-unit {
  font-size: 18rpx;
  color: #707363;
  margin-top: 4rpx;
}

.ex-tips {
  margin-top: 18rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.03);
  display: flex;
  gap: 10rpx;
  align-items: flex-start;
}

.tips-icon {
  font-size: 22rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.ex-tips.reason {
  background: rgba(142, 229, 255, 0.06);
}

.tips-text {
  font-size: 22rpx;
  color: #8f937f;
  line-height: 1.6;
}

.ex-tips.reason .tips-text {
  color: #8EE5FF;
}
