@import "../../styles/theme.wxss";

.ai-shell {
  padding-bottom: 300rpx;
}

.chat-section {
  margin-top: 20rpx;
}

.chat-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.assistant-row {
  justify-content: flex-start;
}

.user-row {
  justify-content: flex-end;
}

.chat-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(195, 244, 0, 0.12);
  color: #c3f400;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.chat-bubble {
  max-width: 80%;
  padding: 24rpx 28rpx;
}

.assistant-bubble {
  border-top-left-radius: 8rpx;
}

.user-bubble {
  background: rgba(195, 244, 0, 0.1);
  border-top-right-radius: 8rpx;
}

.chat-text {
  font-size: 26rpx;
  line-height: 1.8;
  color: #e2e2e2;
  white-space: pre-wrap;
  word-break: break-all;
}

.chat-time {
  display: block;
  margin-top: 12rpx;
  font-size: 20rpx;
  color: #707363;
  text-align: right;
}

.loading-row {
  margin-bottom: 24rpx;
}

.loading-bubble {
  padding: 28rpx 40rpx;
}

.typing-dots {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #c3f400;
  animation: dotPulse 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) {
  animation-delay: 0s;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes dotPulse {
  0%, 80%, 100% {
    transform: scale(0.4);
    opacity: 0.3;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

.prompt-title {
  margin-top: 0;
  font-size: 28rpx;
  line-height: 1.4;
}

.input-shell {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 150rpx;
  z-index: 80;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(19, 19, 19, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: #c3f400;
  color: #161e00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.send-btn-disabled {
  opacity: 0.5;
}
