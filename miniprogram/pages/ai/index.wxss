@import "../../styles/theme.wxss";

.ai-shell {
  padding-bottom: 280rpx;
}

.chat-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.chat-row.user {
  justify-content: flex-end;
}

.chat-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(195, 244, 0, 0.12);
  color: #c3f400;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
}

.chat-bubble {
  max-width: 80%;
  padding: 28rpx;
  font-size: 26rpx;
  line-height: 1.7;
}

.user-bubble {
  background: rgba(195, 244, 0, 0.1);
}

.prompt-title {
  margin-top: 0;
  font-size: 28rpx;
  line-height: 1.4;
}

.input-shell {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 150rpx;
  z-index: 80;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(19, 19, 19, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: #c3f400;
  color: #161e00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}
