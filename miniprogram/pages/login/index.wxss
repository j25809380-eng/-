@import "../../styles/theme.wxss";

.login-shell {
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-glow {
  position: absolute;
  width: 560rpx;
  height: 560rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(195, 244, 0, 0.22), transparent 66%);
  top: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  filter: blur(16rpx);
}

.login-card {
  position: relative;
  width: 100%;
  padding: 56rpx 40rpx;
  border-radius: 40rpx;
  background: rgba(19, 19, 19, 0.88);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.36);
}

.login-title {
  margin-top: 24rpx;
  font-size: 72rpx;
  line-height: 1.05;
  font-weight: 900;
}

.login-panel {
  margin-top: 40rpx;
}

.small {
  font-size: 34rpx;
}
