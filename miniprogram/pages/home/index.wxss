@import "../../styles/theme.wxss";

.small {
  font-size: 26rpx;
  line-height: 1.5;
}

.action-pill {
  padding: 0 30rpx;
  height: 84rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.05);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.plan-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.plan-title {
  margin-top: 18rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.plan-meta {
  color: #c3f400;
  font-size: 30rpx;
  font-weight: 900;
}
