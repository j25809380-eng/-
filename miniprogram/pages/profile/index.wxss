@import "../../styles/theme.wxss";

.profile-hero-head {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.profile-hero-copy {
  flex: 1;
  min-width: 0;
}

.avatar-shell {
  position: relative;
  width: 176rpx;
  height: 176rpx;
  border-radius: 44rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.24);
}

.avatar-image,
.avatar-fallback {
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #c3f400, #6d8900);
  color: #161e00;
  font-size: 72rpx;
  font-weight: 900;
}

.avatar-edit {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  bottom: 12rpx;
  height: 42rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(12, 12, 12, 0.72);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
}

.upload-tip {
  margin-bottom: 24rpx;
  color: #9ea391;
  font-size: 22rpx;
  line-height: 1.7;
}
