@import "../../styles/theme.wxss";

.goal-selector {
  display: flex;
  gap: 12rpx;
}

.goal-chip {
  flex: 1;
  height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.04);
  color: #9ea391;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.goal-chip.active-cut {
  background: rgba(255,77,79,0.18);
  color: #ff4d4f;
  border-color: rgba(255,77,79,0.3);
}

.goal-chip.active-bulk {
  background: rgba(195,244,0,0.16);
  color: #c3f400;
  border-color: rgba(195,244,0,0.3);
}

.goal-chip.active-maintain {
  background: rgba(142,229,255,0.16);
  color: #8EE5FF;
  border-color: rgba(142,229,255,0.3);
}

.goal-summary {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 20rpx;
}

.goal-item {
  padding: 18rpx 12rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.03);
  text-align: center;
}

.goal-item-label {
  font-size: 20rpx;
  color: #9ea391;
}

.goal-item-value {
  font-size: 28rpx;
  font-weight: 900;
  color: #c3f400;
  margin-top: 6rpx;
}

.score-card {
  position: relative;
  text-align: center;
  padding: 40rpx 20rpx;
}

.score-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 8rpx solid;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-number {
  font-size: 56rpx;
  font-weight: 900;
}

.score-label {
  font-size: 22rpx;
  color: #9ea391;
  margin-top: 4rpx;
}

.nutrient-bar-shell {
  margin-top: 28rpx;
}

.nutrient-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.nutrient-label {
  width: 72rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #9ea391;
  text-align: right;
}

.nutrient-bar-bg {
  flex: 1;
  height: 28rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.04);
  overflow: hidden;
}

.nutrient-bar-fill {
  height: 100%;
  border-radius: 14rpx;
  transition: width 0.4s;
}

.nutrient-pct {
  width: 72rpx;
  font-size: 22rpx;
  font-weight: 700;
  text-align: right;
}

.status-badge {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  font-size: 18rpx;
  font-weight: 700;
}

.suggestion-item {
  display: flex;
  gap: 14rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.suggestion-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #c3f400;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.suggestion-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.7;
  color: #d2d5c4;
}

.log-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.log-name {
  font-size: 26rpx;
  font-weight: 700;
}

.log-macros {
  font-size: 22rpx;
  color: #9ea391;
  margin-top: 4rpx;
}

.add-btn {
  margin-top: 16rpx;
}

.form-card {
  margin-top: 20rpx;
  padding: 28rpx;
}

.field-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.field-half {
  flex: 1;
}

.meal-chips {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.meal-chip {
  flex: 1;
  height: 60rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.04);
  color: #9ea391;
}

.meal-chip.active {
  background: rgba(195, 244, 0, 0.18);
  color: #c3f400;
}

/* 日期导航 */
.date-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 16rpx 0;
}

.date-arrow {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9ea391;
  font-size: 24rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.04);
}

.date-picker-wrap {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.04);
}

.date-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #c3f400;
}

/* 食物预设 */
.food-input-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

.preset-btn {
  padding: 16rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(195, 244, 0, 0.12);
  color: #c3f400;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

.preset-panel {
  margin-top: 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.03);
  overflow: hidden;
}

.preset-search {
  padding: 16rpx;
}

.preset-list {
  max-height: 400rpx;
}

.preset-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.preset-name {
  font-size: 26rpx;
  font-weight: 600;
}

.preset-macros {
  font-size: 20rpx;
  color: #9ea391;
  display: block;
  margin-top: 4rpx;
}

.preset-add {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(195, 244, 0, 0.15);
  color: #c3f400;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
