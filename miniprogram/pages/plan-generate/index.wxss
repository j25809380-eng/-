@import "../../styles/theme.wxss";

.mode-tabs {
  display: flex;
  gap: 12rpx;
}

.mode-tab {
  flex: 1;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.04);
  color: #8f937f;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.mode-tab.active {
  background: rgba(195, 244, 0, 0.14);
  color: #c3f400;
  border-color: rgba(195, 244, 0, 0.3);
}

.chip-row {
  display: flex;
  gap: 14rpx;
}

.chip-row.wrap {
  flex-wrap: wrap;
}

.chip {
  height: 64rpx;
  padding: 0 32rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.04);
  color: #9ea391;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.chip.active {
  background: rgba(195, 244, 0, 0.14);
  color: #c3f400;
  border-color: rgba(195, 244, 0, 0.3);
}

.level-chip.active {
  background: rgba(142, 229, 255, 0.14);
  color: #8EE5FF;
  border-color: rgba(142, 229, 255, 0.3);
}

.split-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.split-card {
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.split-card.active {
  background: rgba(195, 244, 0, 0.1);
  border-color: rgba(195, 244, 0, 0.3);
}

.split-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #d2d5c4;
}

.split-card.active .split-title {
  color: #c3f400;
}

.preview-card {
  padding: 24rpx 28rpx;
}

.preview-label {
  font-size: 20rpx;
  color: #707363;
}

.preview-text {
  font-size: 24rpx;
  color: #c3f400;
  margin-top: 8rpx;
  display: block;
}

.primary-button.disabled {
  opacity: 0.5;
}
